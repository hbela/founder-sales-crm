# URL of the running web app to capture screenshots from
APP_URL=http://localhost:5173

# Optional: log in before capturing screenshots (required for protected routes).
# Uses the CRM login form. Leave blank to skip login.
LOGIN_EMAIL=
LOGIN_PASSWORD=

# OpenAI TTS narration (leave OPENAI_API_KEY blank to skip audio)
OPENAI_API_KEY=
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=alloy

# Screenshot viewport
VIEWPORT_WIDTH=1920
VIEWPORT_HEIGHT=1080
