{
  "name": "founder-sales-crm",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel dev",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @founder-crm/db prisma:generate",
    "db:migrate": "pnpm --filter @founder-crm/db prisma:migrate",
    "db:seed": "pnpm --filter @founder-crm/db prisma:seed",
    "db:studio": "pnpm --filter @founder-crm/db prisma:studio"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  }
}
