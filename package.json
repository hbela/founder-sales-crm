{
  "name": "founder-sales-crm",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel dev",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "prisma generate --schema=packages/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=packages/db/prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema=packages/db/prisma/schema.prisma",
    "db:seed": "tsx packages/db/prisma/seed.ts",
    "db:studio": "prisma studio --schema=packages/db/prisma/schema.prisma",
    "guide:generate": "tsx scripts/generate-user-guide.ts",
    "guide:publish": "tsx scripts/publish-user-guide.ts",
    "video": "pnpm --filter @founder-crm/video-generator video",
    "video:scenes": "pnpm --filter @founder-crm/video-generator video:scenes",
    "video:screens": "pnpm --filter @founder-crm/video-generator video:screens",
    "video:voice": "pnpm --filter @founder-crm/video-generator video:voice",
    "video:render": "pnpm --filter @founder-crm/video-generator video:render",
    "video:studio": "pnpm --filter @founder-crm/video-generator video:studio",
    "video:browsers": "pnpm --filter @founder-crm/video-generator video:browsers",
    "new-video": "pnpm --filter @founder-crm/new-video video",
    "new-video:script": "pnpm --filter @founder-crm/new-video video:script",
    "new-video:scenes": "pnpm --filter @founder-crm/new-video video:scenes",
    "new-video:screens": "pnpm --filter @founder-crm/new-video video:screens",
    "new-video:voice": "pnpm --filter @founder-crm/new-video video:voice",
    "new-video:render": "pnpm --filter @founder-crm/new-video video:render",
    "new-video:studio": "pnpm --filter @founder-crm/new-video video:studio",
    "new-video:browsers": "pnpm --filter @founder-crm/new-video video:browsers"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "remotion": "^4.0.481",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild"
    ]
  }
}
