# Database
DATABASE_URL="postgresql://user:password@localhost:5432/founder_sales_crm"

# Auth
AUTH_SECRET="change-me-to-a-long-random-string"
SESSION_COOKIE_NAME="fscrm_session"

# Seed admin user (used only by db:seed)
SEED_ADMIN_EMAIL="admin@foundercrm.local"
SEED_ADMIN_PASSWORD="admin123"
SEED_ADMIN_NAME="Founder"

# Email (Resend)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="onboarding@resend.dev"
# Workspace mailbox that receives replies (threaded via reply_to) so n8n's inbox
# watcher can detect them. Falls back to RESEND_FROM_EMAIL when empty.
REPLY_TO_EMAIL=""

# Branding for the React Email (CrmEmail) wrapper applied to every send.
BRAND_NAME="Founder CRM"
BRAND_COLOR="#4f46e5"
BRAND_LOGO_URL=""
BRAND_ADDRESS=""

# Public origin that serves apps/web/public — used to absolutize campaign asset
# paths (email-assets/...). Must be a deployed https origin when sending for real.
EMAIL_ASSET_BASE_URL="http://localhost:5173"

# Inbound webhook secret — required header (x-webhook-secret) for the n8n-driven
# webhooks /api/webhooks/reply and /api/webhooks/unsubscribe. Leave empty in local
# dev to allow unauthenticated calls.
N8N_WEBHOOK_SECRET=""

# n8n REST API — used by `pnpm --filter api sync:ngrok` to patch the Gmail Reply
# Sync workflow with the current ngrok URL on each tunnel restart. Get the key
# from n8n → Settings → API. Optionally override the workflow id / node name and
# the ngrok local API endpoint.
N8N_API_URL="https://n8ndev.appointer.hu"
N8N_API_KEY=""
N8N_REPLY_SYNC_WORKFLOW_ID="XJY0b9iwUrJ1AGeC"
N8N_REPLY_SYNC_NODE="Extract Reply"
NGROK_API_URL="http://127.0.0.1:4040/api/tunnels"
# --watch poll interval in seconds (the --interval flag overrides this).
NGROK_POLL_SECONDS="5"

# Prospecting — Google Places (discovery). Leave empty to use simulated results.
GOOGLE_PLACES_API_KEY=""

# Prospecting — GLM 5.2 (website enrichment). Z.ai is OpenAI-compatible.
GLM_API_KEY=""
GLM_BASE_URL="https://api.z.ai/api/paas/v4/"
GLM_MODEL="glm-5.2"

# MCP
STITCH_API_KEY=""

# URLs
WEB_URL="http://localhost:5173"
API_URL="http://localhost:4000"

# Portfolio publishing (scripts/publish-user-guide.ts pushes docs/user-guide.md
# to the my-blog portfolio's POST /api/projects/import). PORTFOLIO_IMPORT_SECRET
# must match my-blog's IMPORT_API_SECRET. PORTFOLIO_PUBLIC_DIR is where the Stitch
# previews are copied (relative paths resolve from the repo root).
PORTFOLIO_API_URL="http://localhost:3000"
PORTFOLIO_IMPORT_SECRET=""
PORTFOLIO_PUBLIC_DIR="../my-blog/public"

# Server
PORT=4000
NODE_ENV="development"
